import random

def hangman():
    words = ["python", "project", "hangman", "computer", "science"]
    word = random.choice(words)
    guessed = ["_"] * len(word)
    attempts = 6
    used = set()

    while attempts > 0 and "_" in guessed:
        print("Word:", " ".join(guessed))
        print("Attempts left:", attempts)
        guess = input("Enter a letter: ").lower()

        if not guess.isalpha() or len(guess) != 1:
            print("Invalid input")
            continue

        if guess in used:
            print("Already used")
            continue

        used.add(guess)

        if guess in word:
            for i in range(len(word)):
                if word[i] == guess:
                    guessed[i] = guess
            print("Correct")
        else:
            attempts -= 1
            print("Wrong")

    if "_" not in guessed:
        print("You win! Word is:", word)
    else:
        print("You lose! Word was:", word)

if __name__ == "__main__":
    hangman()
